{
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["ES2015", "DOM", "DOM.Iterable"],
    "jsx": "react",
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true
  },
  "exclude": [
    "node_modules",
    "build",
    "packages/core/dist",
    "packages/web/dist",
    "packages/web/scripts",
    "packages/web/webpack.config.js",
    "packages/mobile/scripts",
    "packages/mobile/android",
    "packages/mobile/ios",
    "packages/mobile/www",
    "webpack.config.js"
  ]
}
